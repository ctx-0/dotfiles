{
    "$help": "https://aka.ms/terminal-documentation",
    "$schema": "https://aka.ms/terminal-profiles-schema",
    "actions": [],
    "centerOnLaunch": true,
    "copyFormatting": "none",
    "copyOnSelect": false,
    "defaultProfile": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
    "keybindings":
    [
        {
            "id": "Terminal.CopyToClipboard",
            "keys": "ctrl+c"
        },
        {
            "id": "Terminal.PasteFromClipboard",
            "keys": "ctrl+v"
        },
        {
            "id": "Terminal.DuplicatePaneAuto",
            "keys": "alt+shift+d"
        },
        {
            "id": "Terminal.MoveFocusRight",
            "keys": "alt+l"
        },
        {
            "id": "Terminal.MoveFocusUp",
            "keys": "alt+k"
        },
        {
            "id": "Terminal.ClosePane",
            "keys": "ctrl+w"
        },
        {
            "id": "Terminal.MoveFocusLeft",
            "keys": "alt+h"
        },
        {
            "id": "Terminal.MoveFocusDown",
            "keys": "alt+j"
        },
        {
            "id": "Terminal.ToggleFullscreen",
            "keys": "f11"
        }
    ],
    "launchMode": "default",
    "newTabMenu":
    [
        {
            "type": "remainingProfiles"
        }
    ],
    "profiles":
    {
        "defaults":
        {
            "bellStyle": "none",
            "colorScheme": "Gruvbox Dark",
            "cursorShape": "bar",
            "font":
            {
                "face": "DepartureMono Nerd Font Mono",
                "size": 13
            },
            "historySize": 50000,
            "opacity": 60,
            "padding": "16, 16, 16, 16",
            "snapOnInput": true,
            "useAcrylic": true
        },
        "list":
        [
            {
                "backgroundImage": "path/to/img",
                "backgroundImageAlignment": "center",
                "backgroundImageOpacity": 0.15,
                "backgroundImageStretchMode": "uniformToFill",
                "commandline": "\"C:\\Program Files\\PowerShell\\7\\pwsh.exe\" -NoLogo -NoExit",
                "guid": "{574e775e-4f2a-5b96-ac1e-a2962a402336}",
                "hidden": false,
                "name": "PowerShell 7",
                "source": "Windows.Terminal.PowershellCore",
                "startingDirectory": "D:\\projects"
            },
            {
                "commandline": "%SystemRoot%\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
                "guid": "{61c54bbd-c2c6-5271-96e7-009a87ff44bf}",
                "hidden": true,
                "name": "Windows PowerShell (Legacy)"
            },
            {
                "guid": "{2ece5bfe-50ed-5f3a-ab87-5cd4baafed2b}",
                "hidden": true,
                "name": "Git Bash",
                "source": "Git"
            }
        ]
    },
